TZ=UTC
PORT=3333
# Use 0.0.0.0 in Docker / Coolify so the container accepts external traffic
HOST=localhost
LOG_LEVEL=info
APP_KEY=
NODE_ENV=development
SESSION_DRIVER=cookie
# Set false when serving over plain HTTP in production (e.g. Coolify sslip.io without TLS)
# COOKIE_SECURE=false

# Database — use DB_* or a single DATABASE_URL (Coolify Postgres links)
# DATABASE_URL=postgres://user:pass@host:5432/dbname
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=postgres

# Container boot (docker/entrypoint.sh) — off by default; enable on first deploy only
RUN_DICTIONARY_SYNC=false

# Payments (Phase 6) — Lenco mobile money (ZMW)
PAYMENTS_GATEWAY=sandbox
PAYMENTS_CURRENCY=ZMW
PAYMENTS_COUNTRY=zm
PAYMENTS_FEE_BEARER=merchant
PAYMENTS_POLL_TIMEOUT=120
LENCO_BASE_URL=https://api.lenco.co/access/v2
LENCO_API_TOKEN=
LENCO_WEBHOOK_SECRET=
LENCO_OTP_PATH=/collections/mobile-money/otp

# Reports (Phase 7)
REPORT_FACILITY_NAME="Anthu Omwe Health Center"
REPORT_PROVINCE=Central
REPORT_DISTRICT=Chibombo
REPORTS_PROCESS_EXPORTS_SYNC=true

# Redis + reference-data cache (optional locally; use redis in production)
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
CACHE_STORE=memory
CACHE_REF_DATA_TTL=24h
CACHE_QUEUE_TTL=60s
CACHE_RBAC_TTL=1h
# CACHE_PATIENTS_FULL_LIST=true