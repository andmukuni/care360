# Copy to .env.docker for local docker compose:
#   cp .env.docker.example .env.docker
#
# Generate APP_KEY:
#   node ace generate:key

TZ=UTC
NODE_ENV=production
HOST=0.0.0.0
PORT=3333
APP_PORT=3333
LOG_LEVEL=info
APP_KEY=replace-with-node-ace-generate-key-output

SESSION_DRIVER=cookie

# docker-compose postgres service
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_DATABASE=fairview

# Optional: override compose port mappings
POSTGRES_PORT=5432
REDIS_PORT=6379

# Redis + reference-data cache (use redis store when REDIS_HOST is set)
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
CACHE_STORE=memory
CACHE_REF_DATA_TTL=24h

# Reports run inline (no background worker in v1)
REPORTS_PROCESS_EXPORTS_SYNC=true
REPORT_FACILITY_NAME="Anthu Omwe Health Center"
REPORT_PROVINCE=Central
REPORT_DISTRICT=Chibombo

# Set true only on first deploy to seed ICD/NTG/meds/lab dictionary (slow)
RUN_DICTIONARY_SYNC=false

# Payments (sandbox for local)
PAYMENTS_GATEWAY=sandbox
PAYMENTS_CURRENCY=ZMW
PAYMENTS_COUNTRY=zm
PAYMENTS_FEE_BEARER=merchant
PAYMENTS_POLL_TIMEOUT=120
